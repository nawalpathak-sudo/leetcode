# Supabase (browser-safe, exposed to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Supabase (server-only, API routes & middleware)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here

# JWT (for auth sessions)
JWT_SECRET=your_jwt_secret_here

# OTP / WhatsApp
TRUSTSIGNAL_API_KEY=your_trustsignal_api_key
TRUSTSIGNAL_SENDER=919266684830

# Google Sheets Sync
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GSHEET_ID=your_sheet_id
GSHEET_GID=0
SYNC_SECRET=some_random_secret_to_protect_sync_endpoint

# Cron (Vercel auto-sends this header with cron invocations)
CRON_SECRET=some_random_secret_for_cron

# GitHub (for profile sync, optional)
GITHUB_TOKEN=ghp_your_token

# Gemini (BOS PDF extraction)
GEMINI_API_KEY=your_gemini_api_key
